<Window x:Class="MacroscopTestTaskWpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:custom="clr-namespace:MacroscopTestTaskWpfApp.CustomControls"
        xmlns:vm="clr-namespace:MacroscopTestTaskWpfApp.ViewModels" 
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
        mc:Ignorable="d"
        Title="MainWindow" Height="590" Width="840"
        Background="#FFDDDDDD">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" x:Name="ImageLoaderContainer">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <custom:ImageLoader Grid.Column="0"
                                x:Name="ImageLoader1"
                                Delay="2000"
                                Button1Text="START"
                                Button1Command="{Binding StartLoadingImageCommand}"
                                Button1Parameter="{Binding ., ElementName=ImageLoader1}"
                                Button2Text="STOP"
                                Button2Command="{Binding StopLoadingImageCommand}"
                                Button2Parameter="{Binding ., ElementName=ImageLoader1}"
                                IsImageLoaded="{Binding IsImage1Loaded, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged}"/>
            <custom:ImageLoader Grid.Column="2"
                                x:Name="ImageLoader2"
                                Delay="2500"
                                Button1Text="START"
                                Button1Command="{Binding StartLoadingImageCommand}"
                                Button1Parameter="{Binding ., ElementName=ImageLoader2}"
                                Button2Text="STOP"
                                Button2Command="{Binding StopLoadingImageCommand}"
                                Button2Parameter="{Binding ., ElementName=ImageLoader2}"
                                IsImageLoaded="{Binding IsImage2Loaded, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged}"/>
            <custom:ImageLoader Grid.Column="4" 
                                Delay="3000"
                                x:Name="ImageLoader3"
                                Button1Text="START"
                                Button1Command="{Binding StartLoadingImageCommand}"
                                Button1Parameter="{Binding ., ElementName=ImageLoader3}"
                                Button2Text="STOP"
                                Button2Command="{Binding StopLoadingImageCommand}"
                                Button2Parameter="{Binding ., ElementName=ImageLoader3}"
                                IsImageLoaded="{Binding IsImage3Loaded, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>
        <Button Grid.Row="2" 
                Style="{DynamicResource RoundedButtonStyle}"
                Content="LOAD ALL" 
                FontSize="18"
                Command="{Binding LoadAllCommand}"
                CommandParameter="{Binding ., ElementName=ImageLoaderContainer}"/>
        <ProgressBar Grid.Row="4" 
                     Style="{DynamicResource ProgressBarMainStyle}"
                     Minimum="0"
                     Maximum="3"
                     Value="{Binding Progress}"/>
    </Grid>
</Window>
